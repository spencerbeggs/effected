{
	"extends": ["//"],
	"tasks": {
		"build": {
			"cache": false,
			"dependsOn": ["@effected/semver#build:prod"],
			"outputLogs": "full",
			"outputs": ["dist/**"]
		},
		"dev": {
			"cache": false,
			"dependsOn": [],
