{
	"extends": ["//"],
	"tasks": {
		"build": {
			"cache": false,
			"dependsOn": [
				"@effected/jsonc#build:prod",
				"@effected/npm#build:prod",
				"@effected/package-json#build:prod",
				"@effected/semver#build:prod",
				"@effected/yaml#build:prod"
			],
			"outputLogs": "full",
			"outputs": ["dist/**"]
		},
		"dev": {
			"cache": false,
			"dependsOn": [],
			"persistent": true
		},
		"preview": {
			"cache": false,
			"dependsOn": ["build"],
			"persistent": true
		}
	}
}
