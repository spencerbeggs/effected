{
	"name": "@effected/walker",
	"version": "0.0.0",
	"private": true,
	"description": "Upward path traversal as Effect primitives: ascend a directory chain and return the first candidate satisfying a predicate.",
	"keywords": ["path", "traversal", "walk", "find-up", "effect", "effected"],
	"homepage": "https://github.com/spencerbeggs/effected/tree/main/packages/walker#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/effected/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/effected.git",
		"directory": "packages/walker"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@effect/vitest": "catalog:effect",
		"@savvy-web/bundler": "^1.1.14",
		"@types/node": "catalog:silk",
		"effect": "catalog:effect",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"effect": "catalog:effect"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
