{
	"name": "@effected/runtimes",
	"version": "0.1.3",
	"private": true,
	"description": "Resolve semver-compatible Node.js, Bun and Deno runtime versions with offline fallback.",
	"keywords": ["node", "bun", "deno", "runtime", "version", "semver", "resolver", "effect", "effected"],
	"homepage": "https://github.com/spencerbeggs/effected/tree/main/packages/runtimes#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/effected/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/effected.git",
		"directory": "packages/runtimes"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsc --noEmit"
	},
	"dependencies": {
		"@effected/semver": "workspace:~"
	},
	"devDependencies": {
		"@effect/vitest": "catalog:effect",
		"@savvy-web/bundler": "^2.0.5",
		"@types/node": "catalog:silk",
		"effect": "catalog:effect",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"effect": "catalog:effect:peers"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
