{
	"name": "@effected/tsconfig-json",
	"version": "0.2.7",
	"private": true,
	"description": "Composable tsconfig.json handling for Effect: schemas, extends-chain resolution, and config discovery.",
	"keywords": ["tsconfig", "typescript", "config", "extends", "resolution", "effect", "schema", "effected"],
	"homepage": "https://github.com/spencerbeggs/effected/tree/main/packages/tsconfig-json#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/effected/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/effected.git",
		"directory": "packages/tsconfig-json"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@effect/vitest": "catalog:effect",
		"@effected/jsonc": "workspace:*",
		"@effected/walker": "workspace:*",
		"@savvy-web/bundler": "^2.0.5",
		"@types/node": "catalog:silk",
		"effect": "catalog:effect",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"@effected/jsonc": "workspace:~",
		"@effected/walker": "workspace:~",
		"effect": "catalog:effect"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
