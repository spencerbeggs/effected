{
	"name": "@effected/lockfiles",
	"version": "0.0.0",
	"private": true,
	"description": "Pure lockfile parsing for bun, npm, pnpm and yarn Berry into one unified Effect schema model, with pure integrity checking against workspace manifests.",
	"keywords": ["lockfile", "pnpm", "npm", "yarn", "bun", "workspaces", "effect", "schema", "effected"],
	"homepage": "https://github.com/spencerbeggs/effected/tree/main/packages/lockfiles#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/effected/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/effected.git",
		"directory": "packages/lockfiles"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@effect/vitest": "catalog:effect",
		"@effected/jsonc": "workspace:*",
		"@effected/semver": "workspace:*",
		"@effected/yaml": "workspace:*",
		"@savvy-web/bundler": "^1.1.12",
		"@types/node": "catalog:silk",
		"effect": "catalog:effect",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"@effected/jsonc": "workspace:*",
		"@effected/semver": "workspace:*",
		"@effected/yaml": "workspace:*",
		"effect": "catalog:effect"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
