{
	"name": "@effected/npm",
	"version": "0.0.0",
	"private": true,
	"description": "Effect service contracts for resolving pnpm catalog: and workspace: dependency specifiers.",
	"keywords": ["npm", "pnpm", "catalog", "workspace", "resolver", "effect", "schema", "effected"],
	"homepage": "https://github.com/spencerbeggs/effected/packages/npm#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/effected/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/effected.git",
		"directory": "packages/npm"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"types:check": "tsgo --noEmit"
	},
	"devDependencies": {
		"@effect/tsgo": "catalog:effect",
		"@effect/vitest": "catalog:effect",
		"@savvy-web/bundler": "^1.1.9",
		"@types/node": "catalog:silk",
		"effect": "catalog:effect",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"effect": "catalog:effect"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
