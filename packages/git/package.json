{
	"name": "@effected/git",
	"version": "0.4.1",
	"private": true,
	"description": "Typed git introspection over Effect's ChildProcessSpawner: read a repository's state at any ref without checking it out, plus a marked mutating tier.",
	"keywords": ["git", "ls-tree", "merge-base", "ref", "effect", "effected"],
	"homepage": "https://github.com/spencerbeggs/effected/tree/main/packages/git#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/effected/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/effected.git",
		"directory": "packages/git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@effect/platform-node": "catalog:effect",
		"@effect/vitest": "catalog:effect",
		"@savvy-web/bundler": "^2.0.7",
		"@types/node": "catalog:silk",
		"effect": "catalog:effect",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"effect": "catalog:effect:peers"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
