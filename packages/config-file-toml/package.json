{
	"name": "@effected/config-file-toml",
	"version": "0.0.0",
	"private": true,
	"description": "TOML codec adapter plugging @effected/toml into @effected/config-file's ConfigCodec seam.",
	"keywords": ["config", "config-file", "toml", "codec", "effect", "schema", "effected"],
	"homepage": "https://github.com/spencerbeggs/effected/packages/config-file-toml#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/effected/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/effected.git",
		"directory": "packages/config-file-toml"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsgo --noEmit"
	},
	"devDependencies": {
		"@effect/tsgo": "catalog:effect",
		"@effect/vitest": "catalog:effect",
		"@effected/config-file": "workspace:*",
		"@effected/toml": "workspace:*",
		"@savvy-web/bundler": "^1.1.9",
		"@types/node": "catalog:silk",
		"effect": "catalog:effect",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"@effected/config-file": "workspace:*",
		"@effected/toml": "workspace:*",
		"effect": "catalog:effect"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
