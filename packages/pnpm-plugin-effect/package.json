{
	"name": "@effected/pnpm-plugin-effect",
	"version": "0.2.0",
	"private": true,
	"description": "pnpm config dependency for centralized catalog management across the Effected ecosystem.",
	"keywords": ["pnpm", "pnpm-plugin", "config-dependency", "catalog", "monorepo", "effected"],
	"homepage": "https://github.com/spencerbeggs/effected/tree/main/packages/pnpm-plugin-effect#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/effected/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/effected.git",
		"directory": "packages/pnpm-plugin-effect"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"pnpm:export": "node allowed-versions.gen.ts && rolldown-pnpm-config export",
		"pnpm:preview": "rolldown-pnpm-config preview",
		"pnpm:up": "rolldown-pnpm-config upgrade savvy.build.ts",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@effect/vitest": "catalog:effect",
		"@savvy-web/bundler": "^2.0.3",
		"@types/node": "catalog:silk",
		"effect": "catalog:effect",
		"rolldown-pnpm-config": "^0.4.0",
		"typescript": "catalog:silk"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
