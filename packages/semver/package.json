{
	"name": "@effected/semver",
	"version": "0.0.0",
	"private": true,
	"description": "pnpm config dependency for centralized catalog management across the Effected ecosystem.",
	"keywords": ["pnpm", "pnpm-plugin", "config-dependency", "catalog", "monorepo", "effected"],
	"homepage": "https://github.com/spencerbeggs/effected/packages/semver#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/effected/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/effected.git",
		"directory": "packages/semver"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsgo --noEmit"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^1.1.4",
		"@types/node": "catalog:silk",
		"@typescript/native-preview": "catalog:silk",
		"rolldown-pnpm-config": "^0.2.0",
		"typescript": "catalog:silk"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
