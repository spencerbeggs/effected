{
	"name": "@effected/ts-vfs",
	"version": "0.0.0",
	"private": true,
	"description": "TypeScript virtual file systems for Effect: fetch, cache and resolve type definitions from npm via the jsDelivr CDN, and build @typescript/vfs environments for Twoslash-style documentation tooling.",
	"keywords": ["typescript", "vfs", "twoslash", "types", "jsdelivr", "cache", "effect", "effected"],
	"homepage": "https://github.com/spencerbeggs/effected/packages/ts-vfs#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/effected/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/effected.git",
		"directory": "packages/ts-vfs"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsgo --noEmit"
	},
	"devDependencies": {
		"@effect/platform-node": "catalog:effect",
		"@effect/tsgo": "catalog:effect",
		"@effect/vitest": "catalog:effect",
		"@effected/semver": "workspace:*",
		"@effected/store": "workspace:*",
		"@effected/xdg": "workspace:*",
		"@savvy-web/bundler": "^1.1.9",
		"@types/node": "catalog:silk",
		"@typescript/vfs": "^1.6.4",
		"effect": "catalog:effect",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"@effected/semver": "workspace:*",
		"@effected/store": "workspace:*",
		"@effected/xdg": "workspace:*",
		"@typescript/vfs": "^1.6.4",
		"effect": "catalog:effect",
		"typescript": ">=5.5"
	},
	"peerDependenciesMeta": {
		"@typescript/vfs": {
			"optional": true
		},
		"typescript": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
