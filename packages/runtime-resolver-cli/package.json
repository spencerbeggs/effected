{
	"name": "@effected/runtime-resolver-cli",
	"version": "0.0.0",
	"private": true,
	"description": "Command-line interface for @effected/runtimes.",
	"keywords": ["node", "bun", "deno", "runtime", "version", "semver", "resolver", "cli", "effect", "effected"],
	"homepage": "https://github.com/spencerbeggs/effected/tree/main/packages/runtime-resolver-cli#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/effected/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/effected.git",
		"directory": "packages/runtime-resolver-cli"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"bin": {
		"runtime-resolver": "./src/bin.ts"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsc --noEmit"
	},
	"dependencies": {
		"@effect/platform-node": "catalog:effect",
		"@effected/runtimes": "workspace:*",
		"effect": "catalog:effect"
	},
	"devDependencies": {
		"@effect/vitest": "catalog:effect",
		"@savvy-web/bundler": "^1.1.13",
		"@types/node": "catalog:silk",
		"typescript": "catalog:silk"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
