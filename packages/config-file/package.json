{
	"name": "@effected/config-file",
	"version": "0.1.7",
	"private": true,
	"description": "Composable config file loading for Effect: JSON, JSONC, YAML and TOML codecs, resolution strategies, and merge behaviors.",
	"keywords": [
		"config",
		"config-file",
		"codec",
		"json",
		"jsonc",
		"yaml",
		"toml",
		"resolver",
		"merge-strategy",
		"effect",
		"schema",
		"effected"
	],
	"homepage": "https://github.com/spencerbeggs/effected/tree/main/packages/config-file#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/effected/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/effected.git",
		"directory": "packages/config-file"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@effect/platform-node": "catalog:effect",
		"@effect/vitest": "catalog:effect",
		"@effected/jsonc": "workspace:*",
		"@effected/toml": "workspace:*",
		"@effected/walker": "workspace:*",
		"@effected/yaml": "workspace:*",
		"@savvy-web/bundler": "^2.0.7",
		"@types/node": "catalog:silk",
		"effect": "catalog:effect",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"@effected/jsonc": "workspace:~",
		"@effected/toml": "workspace:~",
		"@effected/walker": "workspace:~",
		"@effected/yaml": "workspace:~",
		"effect": "catalog:effect:peers"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
