{
	"name": "@effected/config-file",
	"version": "0.0.0",
	"private": true,
	"description": "Composable config file loading for Effect: pluggable codecs, resolution strategies, and merge behaviors.",
	"keywords": ["config", "config-file", "codec", "resolver", "merge-strategy", "effect", "schema", "effected"],
	"homepage": "https://github.com/spencerbeggs/effected/packages/config-file#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/effected/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/effected.git",
		"directory": "packages/config-file"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"prepare": "turbo run build:dev",
		"types:check": "tsgo --noEmit"
	},
	"devDependencies": {
		"@effect/platform-node": "catalog:effect",
		"@effect/tsgo": "catalog:effect",
		"@effect/vitest": "catalog:effect",
		"@types/node": "catalog:silk",
		"effect": "catalog:effect",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"effect": "catalog:effect"
	},
	"engines": {
		"node": ">=24.11.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true
		}
	}
}
