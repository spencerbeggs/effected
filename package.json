{
	"name": "effected",
	"version": "0.0.0",
	"private": true,
	"description": "A template repository for developing and deploying Node.js modules from a pnpm monorepo structure.",
	"homepage": "https://github.com/spencerbeggs/effected#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/effected/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/effected.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build": "turbo run build:dev build:prod --log-order=grouped --log-prefix=none",
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"ci:test": "CI=\"true\" vitest run --passWithNoTests",
		"dev": "turbo run dev --filter=docs",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"pnpm:export": "pnpm --filter '@effected/pnpm-plugin-effect' run pnpm:export",
		"pnpm:preview": "pnpm --filter '@effected/pnpm-plugin-effect' run pnpm:preview",
		"pnpm:up": "pnpm --filter '@effected/pnpm-plugin-effect' run pnpm:up",
		"prepare": "husky",
		"preview": "turbo run preview --filter=docs",
		"test": "vitest run --passWithNoTests",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsgo --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "~2.5.0",
		"@changesets/cli": "^3.0.0-next.8",
		"@commitlint/cli": "^21.2.0",
		"@commitlint/config-conventional": "^21.2.0",
		"@savvy-web/bundler": "^1.1.8",
		"@savvy-web/changelog": "0.1.1",
		"@savvy-web/cli": "1.5.2",
		"@savvy-web/mcp": "1.6.7",
		"@savvy-web/silk": "^2.1.3",
		"@types/node": "catalog:silk",
		"@typescript/native-preview": "catalog:silk",
		"@vitest-agent/cli": "1.0.6",
		"@vitest-agent/mcp": "1.3.4",
		"@vitest-agent/plugin": "^1.1.7",
		"@vitest/coverage-istanbul": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"commitizen": "^4.3.2",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"markdownlint-cli2": "^0.23.0",
		"markdownlint-cli2-formatter-codequality": "^0.0.7",
		"turbo": "^2.10.2",
		"typescript": "catalog:silk",
		"vitest": "^4.1.0"
	},
	"packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
	"engines": {
		"node": ">=24.11.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "26.4.0",
				"onFail": "ignore"
			}
		]
	}
}
